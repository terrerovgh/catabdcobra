---
import { altLocalePath, useDict, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useDict(locale);
const href = altLocalePath(locale, Astro.url.pathname);
---

<a
  href={href}
  aria-label={t.lang.label}
  class="grid h-9 min-w-9 place-items-center rounded-full border border-line bg-surface-2 px-2 font-display text-xs font-semibold text-ink-soft transition-colors hover:text-ink"
>
  {locale === 'en' ? 'ES' : 'EN'}
</a>
