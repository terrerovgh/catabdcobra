---
/**
 * The Cobra — layered SVG traced from the studio logo: the draped hood
 * (the shape that saddles the cat's back in the logo) forms the base,
 * an S-curved neck climbs with a ladder of cream belly scutes, and a
 * small dark-teal head tips forward. Neck sways, tongue flicks.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={`cobra-svg ${className}`}
  viewBox="0 0 230 340"
  fill="none"
  aria-hidden="true"
  role="img"
>
  <g class="anim-sway">
    <!-- neck: ink edge, teal body, cream belly, scute rungs -->
    <path d="M128 262 C148 216 106 172 116 128 C120 104 120 88 112 72" stroke="#57462f" stroke-width="36" stroke-linecap="round"></path>
    <path d="M128 262 C148 216 106 172 116 128 C120 104 120 88 112 72" stroke="#87a794" stroke-width="29" stroke-linecap="round"></path>
    <path d="M124 258 C144 214 102 170 112 128 C116 104 116 88 108 74" stroke="#f0e7c9" stroke-width="13" stroke-linecap="round"></path>
    <g stroke="#57462f" stroke-width="2.4" stroke-linecap="round">
      <path d="M126 246 L140 250"></path>
      <path d="M128 230 L142 232"></path>
      <path d="M126 214 L140 214"></path>
      <path d="M120 198 L134 196"></path>
      <path d="M113 182 L127 179"></path>
      <path d="M108 166 L122 163"></path>
      <path d="M106 150 L120 148"></path>
      <path d="M106 134 L120 133"></path>
      <path d="M108 118 L122 118"></path>
      <path d="M110 102 L124 103"></path>
      <path d="M108 88 L122 90"></path>
    </g>

    <!-- small dark head tipping forward -->
    <g transform="rotate(-10 106 56) translate(-12.72 -6.72) scale(1.12)">
      <path
        d="M78 66 C72 50 84 36 104 34 C124 32 138 42 136 56 C134 68 122 74 106 73 C94 72 84 72 78 66 Z"
        fill="#5e7d6d" stroke="#57462f" stroke-width="4.5" stroke-linejoin="round"
      ></path>
      <circle cx="93" cy="52" r="4.5" fill="#26231f"></circle>
      <circle cx="94.5" cy="50.5" r="1.4" fill="#f0e7c9"></circle>
      <path d="M79 63 Q87 67 97 66" stroke="#57462f" stroke-width="2.6" stroke-linecap="round"></path>
      <g class="anim-tongue">
        <path d="M78 64 L60 64 M60 64 L51 58 M60 64 L53 71" stroke="#c26a4a" stroke-width="3.4" stroke-linecap="round"></path>
      </g>
    </g>
  </g>

  <!-- draped hood: the saddle shape from the logo, as the base -->
  <path
    d="M42 296 C38 258 68 230 114 228 C162 230 196 258 192 298 C190 320 160 332 116 332 C72 332 46 320 42 296 Z"
    fill="#87a794" stroke="#57462f" stroke-width="4.5" stroke-linejoin="round"
  ></path>
  <!-- segmented belly band along its lower edge -->
  <path
    d="M52 306 C76 322 158 322 182 304 L 182 310 C160 328 76 328 52 314 Z"
    fill="#f0e7c9" stroke="#57462f" stroke-width="3"
  ></path>
  <g stroke="#57462f" stroke-width="2.2" stroke-linecap="round">
    <path d="M70 314 L70 322"></path>
    <path d="M92 318 L92 326"></path>
    <path d="M116 320 L116 327"></path>
    <path d="M140 318 L140 326"></path>
    <path d="M162 314 L162 321"></path>
  </g>
  <!-- crease where the neck emerges from the drape -->
  <path d="M92 238 C104 250 132 252 148 244" stroke="#57462f" stroke-width="3" stroke-linecap="round" opacity="0.55"></path>
</svg>
