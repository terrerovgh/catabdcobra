---
/**
 * The Cobra — the exact snake from the studio logo (hooded head, scute
 * ladder neck, draped coil), extracted whole from the original artwork by
 * scripts/build-logo-characters.py. Sways gently from its base.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<img
  class={`anim-sway ${className}`}
  src={`${base}/logo/char-cobra.webp`}
  width="244"
  height="442"
  alt=""
  aria-hidden="true"
  loading="lazy"
  decoding="async"
  draggable="false"
/>
