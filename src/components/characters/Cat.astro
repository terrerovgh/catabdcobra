---
/**
 * The Cat — the exact lounging cat from the studio logo, extracted from the
 * original artwork by scripts/build-logo-characters.py (the back it hides
 * under the cobra's coil is rebuilt with the same fur color and ink line).
 * Breathes softly.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<img
  class={`anim-breathe ${className}`}
  src={`${base}/logo/char-cat.webp`}
  width="520"
  height="383"
  alt=""
  aria-hidden="true"
  loading="lazy"
  decoding="async"
  draggable="false"
/>
