---
/**
 * The animated logo — built from the ORIGINAL studio artwork, not a trace.
 * `scripts/build-logo-layers.py` slices src/assets/logo-original.png into
 * three stacked full-bleed layers (same 779×779 canvas):
 *   1. logo-base  — badge, peach circle, cat and coil, with the cobra's
 *      neck+head removed and the background reconstructed behind it,
 *   2. logo-cobra — just the neck+head cutout, the layer that sways,
 *   3. logo-coil  — a static copy of the coil's top edge that sits on top
 *      and hides the cutout's lower edge where the neck slips behind it.
 * The scene assembles on first paint, breathes, sways the cobra from the
 * exact point the neck leaves the coil, tilts with pointer/gyro, comes
 * apart on scroll, and morphs into the header brand mark via view
 * transitions. Layer nesting: scroll-driven ▸ parallax ▸ assemble ▸ sway.
 */
---

<div
  class="logo-scene anim-breathe relative mx-auto aspect-square w-full max-w-sm"
  data-hero-scene
  transition:name="brand"
  role="img"
  aria-label="Cat & Cobra Tattoo Studio logo"
>
  <!-- badge + circle + cat + coil (cobra removed, background rebuilt) -->
  <div class="logo-layer logo-base absolute inset-0">
    <div class="parallax h-full w-full" style="--depth: 6px">
      <img
        class="anim-bloom h-full w-full drop-shadow-lg"
        src="/logo/logo-base.webp"
        width="779"
        height="779"
        alt=""
        loading="eager"
        decoding="async"
        draggable="false"
      />
    </div>
  </div>

  <!-- the cobra's neck + head: rises from behind the coil, then sways -->
  <div class="logo-layer logo-cobra absolute inset-0">
    <div class="parallax h-full w-full" style="--depth: 10px">
      <div class="anim-rise h-full w-full" style="animation-delay: 380ms">
        <div class="cobra-sway h-full w-full">
          <img
            class="h-full w-full"
            src="/logo/logo-cobra.webp"
            width="779"
            height="779"
            alt=""
            loading="eager"
            decoding="async"
            draggable="false"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- static patch of the coil's top edge — the neck slides in behind it -->
  <div class="logo-layer logo-base absolute inset-0">
    <div class="parallax h-full w-full" style="--depth: 6px">
      <img
        class="anim-bloom h-full w-full"
        src="/logo/logo-coil.webp"
        width="779"
        height="779"
        alt=""
        loading="eager"
        decoding="async"
        draggable="false"
      />
    </div>
  </div>

  <!-- two quiet specks of depth -->
  <div class="logo-layer absolute inset-0" aria-hidden="true">
    <div class="parallax h-full w-full" style="--depth: 22px">
      <span class="anim-float absolute top-[14%] left-[15%] h-2 w-2 rounded-full bg-duo opacity-50"></span>
      <span class="anim-float absolute right-[10%] bottom-[26%] h-1.5 w-1.5 rounded-full bg-accent opacity-40" style="animation-delay: -3s"></span>
    </div>
  </div>
</div>

<style>
  .parallax {
    transform: translate3d(
      calc(var(--px, 0) * var(--depth, 8px)),
      calc(var(--py, 0) * var(--depth, 8px)),
      0
    );
    transition: transform 250ms ease-out;
    will-change: transform;
  }

  /* the cobra sways like a pendulum from where the neck leaves the coil —
     pivot (467,385) on the 779×779 canvas */
  .cobra-sway {
    transform-origin: 59.95% 49.42%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cobra-sway {
      animation: cobra-sway 3.6s ease-in-out infinite;
      will-change: transform;
    }
  }
  @keyframes cobra-sway {
    0%,
    100% {
      transform: rotate(-2.2deg);
    }
    50% {
      transform: rotate(7deg);
    }
  }

  /* soften the artwork a touch in the dark theme (on the container, so it
     composites once and doesn't clobber the base image's drop-shadow) */
  :global(html[data-theme='cobra']) .logo-scene {
    filter: brightness(0.94) saturate(0.96);
  }

  /* The logo comes apart as you scroll away from the hero: the cobra
     drifts off the cat's back (base + coil patch travel together) */
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .logo-layer {
        animation: none linear both;
        animation-timeline: scroll(root);
        animation-range: 0 70vh;
      }
      .logo-base {
        animation-name: logo-base-part;
      }
      .logo-cobra {
        animation-name: logo-cobra-part;
      }
    }
  }
  @keyframes logo-base-part {
    to {
      transform: translate(-16px, 10px);
      opacity: 0.85;
    }
  }
  @keyframes logo-cobra-part {
    to {
      transform: translate(28px, -18px);
      opacity: 0.85;
    }
  }
</style>

<script>
  function initHero() {
    const scene = document.querySelector<HTMLElement>('[data-hero-scene]');
    if (!scene || scene.dataset.init) return;
    scene.dataset.init = '1';
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const set = (x: number, y: number) => {
      scene.style.setProperty('--px', String(Math.max(-1, Math.min(1, x))));
      scene.style.setProperty('--py', String(Math.max(-1, Math.min(1, y))));
    };

    window.addEventListener(
      'pointermove',
      (e) => {
        const r = scene.getBoundingClientRect();
        set(
          (e.clientX - (r.left + r.width / 2)) / (r.width / 2),
          (e.clientY - (r.top + r.height / 2)) / (r.height / 2),
        );
      },
      { passive: true },
    );

    window.addEventListener(
      'deviceorientation',
      (e) => {
        if (e.gamma == null || e.beta == null) return;
        set(e.gamma / 35, (e.beta - 45) / 35);
      },
      { passive: true },
    );
  }
  document.addEventListener('astro:page-load', initHero);
</script>
