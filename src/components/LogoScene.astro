---
/**
 * The animated logo — the studio emblem rebuilt layer by layer, traced 1:1
 * from the logo video (all layers share one 720×720 scene grid, so stacking
 * them full-bleed reproduces the artwork exactly). Layer order matters:
 * neck+head behind the cat, coil in front of it, tail on top of the coil.
 * The scene can:
 *   1. assemble itself on first paint,
 *   2. live subtly (cobra sway + head whip, cat breathing),
 *   3. come apart on scroll (disc opens, cobra parts drift together) — the
 *      logo "transforms" into the page,
 *   4. morph into the header brand mark via view transitions.
 * Each layer nests three wrappers: scroll-driven ▸ parallax ▸ assemble.
 */
import EmblemCat from './emblem/EmblemCat.astro';
import EmblemCobra from './emblem/EmblemCobra.astro';
import EmblemCoil from './emblem/EmblemCoil.astro';
---

<div
  class="logo-scene relative mx-auto aspect-square w-full max-w-sm"
  data-hero-scene
  transition:name="brand"
>
  <!-- cream badge disc: center (360,360) r350 on the 720 grid -->
  <div class="logo-layer logo-disc absolute inset-[1.4%]">
    <div class="parallax h-full w-full" style="--depth: 4px">
      <div
        class="anim-bloom h-full w-full rounded-full shadow-(--shadow-card) transition-colors duration-300"
        style="background: var(--scene-badge)"
      >
      </div>
    </div>
  </div>

  <!-- peach circle: center (365,381) r243 on the 720 grid -->
  <div class="logo-layer logo-ring absolute" style="left: 17%; top: 19.2%; width: 67.5%; height: 67.5%">
    <div class="parallax h-full w-full" style="--depth: 8px">
      <div
        class="anim-bloom h-full w-full rounded-full transition-colors duration-300"
        style="background: var(--scene-disc); animation-delay: 120ms"
      >
      </div>
    </div>
  </div>

  <!-- cobra neck + head, rising behind the cat -->
  <div class="logo-layer logo-cobra absolute inset-0">
    <div class="parallax h-full w-full" style="--depth: 12px">
      <div class="anim-rise h-full w-full" style="animation-delay: 420ms">
        <EmblemCobra class="h-full w-full" />
      </div>
    </div>
  </div>

  <!-- cat lounging in front of the neck -->
  <div class="logo-layer logo-cat absolute inset-0">
    <div class="parallax h-full w-full" style="--depth: 16px">
      <div class="anim-rise h-full w-full" style="animation-delay: 260ms">
        <EmblemCat class="h-full w-full drop-shadow-sm" />
      </div>
    </div>
  </div>

  <!-- coil draped over the cat's back (tail tucks over its tip) -->
  <div class="logo-layer logo-coil absolute inset-0">
    <div class="parallax h-full w-full" style="--depth: 14px">
      <div class="anim-rise h-full w-full" style="animation-delay: 340ms">
        <EmblemCoil class="h-full w-full" />
      </div>
    </div>
  </div>

  <!-- two quiet specks of depth -->
  <div class="logo-layer absolute inset-0" aria-hidden="true">
    <div class="parallax h-full w-full" style="--depth: 22px">
      <span class="anim-float absolute top-[14%] left-[15%] h-2 w-2 rounded-full bg-duo opacity-50"></span>
      <span class="anim-float absolute right-[10%] bottom-[26%] h-1.5 w-1.5 rounded-full bg-accent opacity-40" style="animation-delay: -3s"></span>
    </div>
  </div>
</div>

<style>
  .parallax {
    transform: translate3d(
      calc(var(--px, 0) * var(--depth, 8px)),
      calc(var(--py, 0) * var(--depth, 8px)),
      0
    );
    transition: transform 250ms ease-out;
    will-change: transform;
  }

  /* The logo opens up as you scroll away from the hero */
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .logo-layer {
        animation: none linear both;
        animation-timeline: scroll(root);
        animation-range: 0 70vh;
      }
      .logo-disc {
        animation-name: logo-disc-open;
      }
      .logo-ring {
        animation-name: logo-ring-open;
      }
      .logo-cat {
        animation-name: logo-cat-part;
      }
      /* neck and coil are one snake — they drift away together */
      .logo-cobra,
      .logo-coil {
        animation-name: logo-cobra-part;
      }
    }
  }
  @keyframes logo-disc-open {
    to {
      transform: scale(1.3);
      opacity: 0;
    }
  }
  @keyframes logo-ring-open {
    to {
      transform: scale(1.12);
      opacity: 0.35;
    }
  }
  @keyframes logo-cat-part {
    to {
      transform: translate(-30px, 14px);
    }
  }
  @keyframes logo-cobra-part {
    to {
      transform: translate(30px, -18px);
    }
  }
</style>

<script>
  function initHero() {
    const scene = document.querySelector<HTMLElement>('[data-hero-scene]');
    if (!scene || scene.dataset.init) return;
    scene.dataset.init = '1';
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const set = (x: number, y: number) => {
      scene.style.setProperty('--px', String(Math.max(-1, Math.min(1, x))));
      scene.style.setProperty('--py', String(Math.max(-1, Math.min(1, y))));
    };

    window.addEventListener(
      'pointermove',
      (e) => {
        const r = scene.getBoundingClientRect();
        set(
          (e.clientX - (r.left + r.width / 2)) / (r.width / 2),
          (e.clientY - (r.top + r.height / 2)) / (r.height / 2),
        );
      },
      { passive: true },
    );

    window.addEventListener(
      'deviceorientation',
      (e) => {
        if (e.gamma == null || e.beta == null) return;
        set(e.gamma / 35, (e.beta - 45) / 35);
      },
      { passive: true },
    );
  }
  document.addEventListener('astro:page-load', initHero);
</script>
