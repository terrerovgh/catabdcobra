---
import { artists } from '../data/artists';
import { styles } from '../data/styles';
import { designs } from '../data/designs';
import { useDict, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  /** Optional: lock filters when embedding on an artist page. */
  artistId?: string;
  styleId?: string;
}
const { locale, artistId, styleId } = Astro.props;
const t = useDict(locale);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const apiUrl = artistId
  ? `${base}/api/public/profile-gallery/${artistId}`
  : `${base}/api/public/gallery`;

const showArtistFilter = !artistId;
const showStyleFilter = !styleId;

const styleLabels = Object.fromEntries(styles.map((s) => [s.id, s.name[locale]]));
const designLabels = Object.fromEntries(designs.map((d) => [d.id, d.name[locale]]));
const artistLabels = Object.fromEntries(artists.map((a) => [a.id, a.handle]));
---

<div
  data-gallery
  data-api={apiUrl}
  data-mode={artistId ? 'profile' : 'gallery'}
  data-locked-artist={artistId ?? ''}
  data-locked-style={styleId ?? ''}
  data-locale={locale}
  data-labels={JSON.stringify({
    styles: styleLabels,
    designs: designLabels,
    artists: artistLabels,
    fresh: t.gallery.fresh,
    healed: t.gallery.healed,
    emptyTitle: t.gallery.emptyTitle,
    emptyBody: t.gallery.emptyBody,
    loading: locale === 'es' ? 'Cargando…' : 'Loading…',
  })}
>
  {
    showStyleFilter && (
      <div class="swipe-deck !gap-2 !px-5 pb-2" role="group" aria-label={t.gallery.filterStyle} data-style-chips>
        <button type="button" class="chip active" data-filter-style="all">
          {t.gallery.all}
        </button>
        {styles.map((s) => (
          <button type="button" class="chip" data-filter-style={s.id}>
            {s.name[locale]}
          </button>
        ))}
      </div>
    )
  }

  {
    showArtistFilter && (
      <div class="swipe-deck !gap-2 !px-5 pb-2" role="group" aria-label={t.gallery.filterArtist} data-artist-chips>
        <button type="button" class="chip active" data-filter-artist="all">
          {t.gallery.all}
        </button>
        {artists.map((a) => (
          <button type="button" class="chip" data-filter-artist={a.id}>
            {a.handle}
          </button>
        ))}
      </div>
    )
  }

  <div class="swipe-deck !gap-2 !px-5 pb-4 hidden" role="group" aria-label={t.gallery.filterDesign} data-design-chips>
    <button type="button" class="chip active" data-filter-design="all">
      {t.gallery.all}
    </button>
  </div>

  <p data-gallery-loading class="mx-5 rounded-2xl border border-line bg-surface p-5 text-center text-sm text-ink-soft">
    {locale === 'es' ? 'Cargando…' : 'Loading…'}
  </p>

  <div class="grid grid-cols-2 gap-3 px-5" data-gallery-grid></div>

  <p data-gallery-empty class="mx-5 mt-4 hidden rounded-2xl border border-line bg-surface p-5 text-center text-sm text-ink-soft">
    <strong class="font-display text-ink">{t.gallery.emptyTitle}</strong>
    <br />
    {t.gallery.emptyBody}
  </p>
</div>

<style>
  .chip {
    flex: 0 0 auto;
    scroll-snap-align: start;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    transition: all 200ms ease;
  }
  .chip.active {
    background: var(--accent);
    border-color: transparent;
    color: #26231f;
  }
  .seg.active {
    background: var(--accent);
    color: #26231f;
  }
</style>

<script>
  type MediaItem = {
    id: string;
    artist_id?: string | null;
    style_id?: string | null;
    design_id?: string | null;
    slug?: string | null;
    variant?: string | null;
    title?: string | null;
    caption?: string | null;
    alt?: { en?: string | null; es?: string | null };
    tags?: string[];
    url: string;
  };

  function initGallery() {
    const root = document.querySelector<HTMLElement>('[data-gallery]');
    if (!root || root.dataset.init) return;
    root.dataset.init = '1';

    const api = root.dataset.api!;
    const labels = JSON.parse(root.dataset.labels || '{}') as {
      styles: Record<string, string>;
      designs: Record<string, string>;
      artists: Record<string, string>;
      fresh: string;
      healed: string;
      emptyTitle: string;
      emptyBody: string;
    };
    const locale = root.dataset.locale || 'en';

    const state = {
      style: root.dataset.lockedStyle || 'all',
      artist: root.dataset.lockedArtist || 'all',
      design: 'all',
    };

    const grid = root.querySelector<HTMLElement>('[data-gallery-grid]')!;
    const loadingEl = root.querySelector<HTMLElement>('[data-gallery-loading]');
    const emptyEl = root.querySelector<HTMLElement>('[data-gallery-empty]');
    const designChips = root.querySelector<HTMLElement>('[data-design-chips]');

    const applyFilters = () => {
      let visible = 0;
      root.querySelectorAll<HTMLElement>('.gallery-card').forEach((card) => {
        const show =
          (state.style === 'all' || card.dataset.style === state.style) &&
          (state.artist === 'all' || card.dataset.artist === state.artist) &&
          (state.design === 'all' || card.dataset.design === state.design);
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      emptyEl?.classList.toggle('hidden', visible > 0);
    };

    const render = (items: MediaItem[]) => {
      loadingEl?.classList.add('hidden');
      grid.innerHTML = '';

      if (!items.length) {
        emptyEl?.classList.remove('hidden');
        return;
      }
      emptyEl?.classList.add('hidden');

      // Design chips from data
      const usedDesigns = new Set(items.map((i) => i.design_id).filter(Boolean) as string[]);
      if (designChips && usedDesigns.size) {
        designChips.classList.remove('hidden');
        // keep "all" button, append design chips
        const allBtn = designChips.querySelector('[data-filter-design="all"]');
        designChips.innerHTML = '';
        if (allBtn) designChips.appendChild(allBtn);
        else {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'chip active';
          b.dataset.filterDesign = 'all';
          b.textContent = locale === 'es' ? 'Todos' : 'All';
          designChips.appendChild(b);
        }
        for (const id of usedDesigns) {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'chip';
          b.dataset.filterDesign = id;
          b.textContent = labels.designs[id] || id;
          designChips.appendChild(b);
        }
      }

      // Group fresh/healed pairs by artist+style+slug when possible
      const groups = new Map<string, { fresh?: MediaItem; healed?: MediaItem; any: MediaItem }>();
      for (const item of items) {
        const key = `${item.artist_id || ''}__${item.style_id || ''}__${item.slug || item.id}`;
        const g = groups.get(key) || { any: item };
        if (item.variant === 'fresh') g.fresh = item;
        else if (item.variant === 'healed') g.healed = item;
        g.any = item;
        groups.set(key, g);
      }

      for (const g of groups.values()) {
        const primary = g.fresh || g.healed || g.any;
        const secondary = g.fresh && g.healed ? g.healed : null;
        const both = !!(g.fresh && g.healed);
        const styleId = primary.style_id || '';
        const artistId = primary.artist_id || '';
        const designId = primary.design_id || 'other';
        const styleName = labels.styles[styleId] || styleId;
        const artistName = labels.artists[artistId] || artistId;
        const designName = labels.designs[designId] || '';
        const alt =
          (locale === 'es' ? primary.alt?.es : primary.alt?.en) ||
          primary.title ||
          [styleName, designName, artistName].filter(Boolean).join(' · ');

        const fig = document.createElement('figure');
        fig.className =
          'gallery-card overflow-hidden rounded-2xl border border-line bg-surface shadow-(--shadow-card)';
        fig.dataset.style = styleId;
        fig.dataset.artist = artistId;
        fig.dataset.design = designId;

        fig.innerHTML = `
          <div class="relative aspect-square">
            <img src="${primary.url}" alt="${escapeHtml(alt)}" width="640" height="640"
              class="variant-fresh absolute inset-0 h-full w-full object-cover" loading="lazy" />
            ${
              both && secondary
                ? `<img src="${secondary.url}" alt="${escapeHtml(alt)} (${labels.healed})" width="640" height="640"
                  class="variant-healed absolute inset-0 h-full w-full object-cover hidden" loading="lazy" />
                <div class="absolute right-2 bottom-2 left-2 flex rounded-full border border-line bg-bg/85 p-0.5 text-[0.65rem] font-bold backdrop-blur-sm">
                  <button type="button" class="seg active flex-1 rounded-full py-1" data-variant="fresh">${labels.fresh}</button>
                  <button type="button" class="seg flex-1 rounded-full py-1" data-variant="healed">${labels.healed}</button>
                </div>`
                : ''
            }
          </div>
          <figcaption class="flex flex-col gap-0.5 p-2.5 text-xs">
            <div class="flex items-center justify-between gap-1">
              <span class="font-display font-semibold">${escapeHtml(styleName)}</span>
              <span class="text-ink-soft">${escapeHtml(artistName)}</span>
            </div>
            ${
              designId && designId !== 'other' && designName
                ? `<span class="text-[0.65rem] font-medium tracking-wide text-ink-soft uppercase">${escapeHtml(designName)}</span>`
                : ''
            }
          </figcaption>
        `;
        grid.appendChild(fig);
      }

      applyFilters();
    };

    function escapeHtml(s: string) {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    root.addEventListener('click', (event) => {
      const el = event.target as HTMLElement;

      const styleChip = el.closest<HTMLElement>('[data-filter-style]');
      const artistChip = el.closest<HTMLElement>('[data-filter-artist]');
      const designChip = el.closest<HTMLElement>('[data-filter-design]');
      if (styleChip || artistChip || designChip) {
        const chip = (styleChip ?? artistChip ?? designChip)!;
        const key = styleChip ? 'style' : artistChip ? 'artist' : 'design';
        const attr = styleChip
          ? 'data-filter-style'
          : artistChip
            ? 'data-filter-artist'
            : 'data-filter-design';
        state[key as 'style' | 'artist' | 'design'] = chip.getAttribute(attr)!;
        chip.parentElement
          ?.querySelectorAll('.chip')
          .forEach((c) => c.classList.toggle('active', c === chip));
        applyFilters();
        return;
      }

      const seg = el.closest<HTMLElement>('.seg[data-variant]');
      if (seg) {
        const card = seg.closest<HTMLElement>('.gallery-card');
        if (!card) return;
        const variant = seg.dataset.variant;
        card.querySelector('.variant-fresh')?.classList.toggle('hidden', variant !== 'fresh');
        card.querySelector('.variant-healed')?.classList.toggle('hidden', variant !== 'healed');
        card.querySelectorAll('.seg').forEach((s) => s.classList.toggle('active', s === seg));
      }
    });

    const hash = location.hash.replace(/^#/, '');
    if (hash) {
      const params = new URLSearchParams(hash.includes('=') ? hash : `artist=${hash}`);
      for (const key of ['artist', 'style', 'design'] as const) {
        const val = params.get(key);
        if (!val) continue;
        state[key] = val;
        const chip = root.querySelector<HTMLElement>(`[data-filter-${key}="${val}"]`);
        if (chip) {
          chip.parentElement
            ?.querySelectorAll('.chip')
            .forEach((c) => c.classList.toggle('active', c === chip));
        }
      }
    }

    fetch(api, { credentials: 'same-origin' })
      .then((r) => r.json())
      .then((json) => {
        if (!json?.ok) throw new Error(json?.error?.message || 'API error');
        const items = (json.data?.media || []) as MediaItem[];
        render(items);
      })
      .catch(() => {
        loadingEl?.classList.add('hidden');
        emptyEl?.classList.remove('hidden');
      });
  }

  document.addEventListener('astro:page-load', initGallery);
</script>
