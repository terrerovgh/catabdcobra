---
import { Image } from 'astro:assets';
import { gallery } from '../data/gallery';
import { artists } from '../data/artists';
import { styles, getStyle } from '../data/styles';
import { useDict, type Locale } from '../i18n';
import Cat from './characters/Cat.astro';
import Cobra from './characters/Cobra.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useDict(locale);

/* Illustrated placeholders keep the grid (and filters) alive until real
   photos land in src/assets/gallery/ — one per style, round-robin artists. */
const placeholders =
  gallery.length > 0
    ? []
    : styles.map((style, i) => ({
        style,
        artist: artists.find((a) => a.styles.includes(style.id)) ?? artists[i % artists.length]!,
      }));
---

<div data-gallery>
  <!-- filter bar: two labelled rows of ghost chips, sticky under the header -->
  <div
    class="sticky z-40 mb-4 border-b border-line bg-bg/85 py-2.5 backdrop-blur-md"
    style="top: calc(3.5rem + env(safe-area-inset-top))"
  >
    <div class="filter-line" role="group" aria-label={t.gallery.filterStyle}>
      <span class="filter-label" aria-hidden="true">{t.gallery.filterStyle}</span>
      <div class="filter-scroll">
        <button type="button" class="fchip active" data-filter-style="all">{t.gallery.all}</button>
        {
          styles.map((s) => (
            <button type="button" class="fchip" data-filter-style={s.id}>
              {s.name[locale]}
            </button>
          ))
        }
      </div>
    </div>
    <div class="filter-line mt-1.5" role="group" aria-label={t.gallery.filterArtist}>
      <span class="filter-label" aria-hidden="true">{t.gallery.filterArtist}</span>
      <div class="filter-scroll">
        <button type="button" class="fchip active" data-filter-artist="all">{t.gallery.all}</button>
        {
          artists.map((a) => (
            <button type="button" class="fchip" data-filter-artist={a.id}>
              {a.handle}
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 px-5">
    {
      gallery.map((piece) => {
        const both = piece.fresh && piece.healed;
        const artist = artists.find((a) => a.id === piece.artist);
        return (
          <figure
            class="gallery-card overflow-hidden rounded-2xl border border-line bg-surface shadow-(--shadow-card)"
            data-style={piece.style}
            data-artist={piece.artist}
            data-photo
          >
            <button
              type="button"
              class="relative block aspect-square w-full cursor-zoom-in"
              data-lb-open
              aria-label={t.gallery.zoom}
            >
              {piece.fresh && (
                <Image
                  src={piece.fresh}
                  alt={`${getStyle(piece.style)?.name[locale] ?? piece.style} — ${artist?.handle ?? piece.artist}`}
                  width={640}
                  class="variant-fresh absolute inset-0 h-full w-full object-cover"
                />
              )}
              {piece.healed && (
                <Image
                  src={piece.healed}
                  alt={`${getStyle(piece.style)?.name[locale] ?? piece.style} (${t.gallery.healed}) — ${artist?.handle ?? piece.artist}`}
                  width={640}
                  class:list={[
                    'variant-healed absolute inset-0 h-full w-full object-cover',
                    piece.fresh && 'hidden',
                  ]}
                />
              )}
            </button>
            {both && (
              <div class="pointer-events-none absolute right-2 bottom-12 left-2 flex rounded-full border border-line bg-bg/85 p-0.5 text-[0.65rem] font-bold backdrop-blur-sm">
                <button type="button" class="seg active pointer-events-auto flex-1 rounded-full py-1" data-variant="fresh">
                  {t.gallery.fresh}
                </button>
                <button type="button" class="seg pointer-events-auto flex-1 rounded-full py-1" data-variant="healed">
                  {t.gallery.healed}
                </button>
              </div>
            )}
            <figcaption class="flex items-center justify-between gap-1 p-2.5 text-xs">
              <span class="caption-style font-display font-semibold">
                {getStyle(piece.style)?.name[locale] ?? piece.style}
              </span>
              <span class="caption-artist text-ink-soft">{artist?.handle ?? piece.artist}</span>
            </figcaption>
          </figure>
        );
      })
    }

    {
      placeholders.map(({ style, artist }) => (
        <figure
          class="gallery-card overflow-hidden rounded-2xl border border-line bg-surface shadow-(--shadow-card)"
          data-style={style.id}
          data-artist={artist.id}
        >
          <div
            class:list={[
              'relative grid aspect-square place-items-center',
              style.mood === 'cat' ? 'bg-accent-soft/40' : 'bg-charcoal/90',
            ]}
            role="img"
            aria-label={t.gallery.placeholderAlt}
          >
            {style.mood === 'cat' ? <Cat class="w-24 opacity-80" /> : <Cobra class="h-24 opacity-80" />}
            <span class="absolute top-2 right-2 rounded-full bg-bg/85 px-2 py-0.5 text-[0.6rem] font-bold tracking-wide uppercase backdrop-blur-sm">
              {t.common.comingSoon}
            </span>
          </div>
          <figcaption class="flex items-center justify-between gap-1 p-2.5 text-xs">
            <span class="font-display font-semibold">{style.name[locale]}</span>
            <span class="text-ink-soft">{artist.handle}</span>
          </figcaption>
        </figure>
      ))
    }
  </div>

  <p data-gallery-empty class="mx-5 mt-4 hidden rounded-2xl border border-line bg-surface p-5 text-center text-sm text-ink-soft">
    <strong class="font-display text-ink">{t.gallery.emptyTitle}</strong>
    <br />
    {t.gallery.emptyBody}
  </p>

  <!-- fullscreen lightbox: swipe / arrows / keyboard to navigate -->
  <div data-lightbox class="lb" role="dialog" aria-modal="true" aria-label={t.gallery.title}>
    <button
      type="button"
      class="lb-btn absolute right-4 z-10"
      style="top: calc(env(safe-area-inset-top) + 0.9rem)"
      data-lb-close
      aria-label={t.gallery.close}
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <div class="flex min-h-0 flex-1 items-center justify-center px-3" data-lb-stage>
      <img data-lb-img class="max-h-full max-w-full rounded-xl object-contain" alt="" />
    </div>

    <button type="button" class="lb-btn lb-nav left-3" data-lb-prev aria-label={t.gallery.prev}>
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 5l-7 7 7 7" />
      </svg>
    </button>
    <button type="button" class="lb-btn lb-nav right-3" data-lb-next aria-label={t.gallery.next}>
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <div class="px-6 pt-3 text-center" style="padding-bottom: calc(env(safe-area-inset-bottom) + 1.25rem)">
      <p class="text-sm">
        <span data-lb-style class="font-display font-semibold"></span>
        <span class="opacity-50"> · </span>
        <span data-lb-artist class="opacity-70"></span>
      </p>
      <div
        data-lb-variants
        class="mx-auto mt-3 hidden w-44 rounded-full border border-white/20 bg-white/10 p-0.5 text-[0.65rem] font-bold"
      >
        <button type="button" class="seg active flex-1 rounded-full py-1" data-lb-variant="fresh">
          {t.gallery.fresh}
        </button>
        <button type="button" class="seg flex-1 rounded-full py-1" data-lb-variant="healed">
          {t.gallery.healed}
        </button>
      </div>
      <p data-lb-count class="mt-2 text-[0.7rem] tracking-widest opacity-50"></p>
    </div>
  </div>
</div>

<style>
  /* --- filter bar ---------------------------------------------------- */
  .filter-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: 1.25rem;
  }
  .filter-label {
    flex: 0 0 3.4rem;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-soft);
  }
  .filter-scroll {
    display: flex;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
    padding-right: 1.25rem;
    mask-image: linear-gradient(to right, transparent, black 10px, black calc(100% - 24px), transparent);
  }
  .filter-scroll::-webkit-scrollbar {
    display: none;
  }
  .fchip {
    flex: 0 0 auto;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-soft);
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }
  .fchip.active {
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent) 13%, transparent);
    border-color: color-mix(in srgb, var(--accent) 32%, transparent);
  }

  .gallery-card {
    position: relative;
  }
  .seg.active {
    background: var(--accent);
    color: #26231f;
  }

  /* --- lightbox ------------------------------------------------------ */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: none;
    flex-direction: column;
    background: rgb(22 20 17 / 0.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    color: #f0e7c9;
    padding-top: calc(env(safe-area-inset-top) + 3.2rem);
  }
  .lb.open {
    display: flex;
    animation: lb-in 220ms ease both;
  }
  @keyframes lb-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .lb img {
    transition: opacity 200ms ease;
    box-shadow: 0 24px 60px -24px rgb(0 0 0 / 0.7);
  }
  .lb-btn {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid rgb(240 231 201 / 0.18);
    background: rgb(240 231 201 / 0.08);
    color: #f0e7c9;
    backdrop-filter: blur(6px);
    transition: background-color 160ms ease;
  }
  .lb-btn:active {
    background: rgb(240 231 201 / 0.2);
  }
  .lb-nav {
    position: absolute;
    top: 50%;
    translate: 0 -50%;
  }
  .lb .seg {
    color: rgb(240 231 201 / 0.75);
  }
  .lb .seg.active {
    color: #26231f;
  }
  [data-lb-variants] {
    display: none;
  }
  [data-lb-variants].show {
    display: flex;
  }
  @media (prefers-reduced-motion: reduce) {
    .lb.open {
      animation: none;
    }
    .lb img {
      transition: none;
    }
  }
</style>

<script>
  function initGallery() {
    const root = document.querySelector<HTMLElement>('[data-gallery]');
    if (!root || root.dataset.init) return;
    root.dataset.init = '1';

    /* ---------- filters ---------- */
    const state = { style: 'all', artist: 'all' };

    const applyFilters = () => {
      let visible = 0;
      root.querySelectorAll<HTMLElement>('.gallery-card').forEach((card) => {
        const show =
          (state.style === 'all' || card.dataset.style === state.style) &&
          (state.artist === 'all' || card.dataset.artist === state.artist);
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      root.querySelector('[data-gallery-empty]')?.classList.toggle('hidden', visible > 0);
    };

    /* ---------- lightbox ---------- */
    type Variant = 'fresh' | 'healed';
    const lb = root.querySelector<HTMLElement>('[data-lightbox]')!;
    const lbImg = lb.querySelector<HTMLImageElement>('[data-lb-img]')!;
    const lbStyle = lb.querySelector<HTMLElement>('[data-lb-style]')!;
    const lbArtist = lb.querySelector<HTMLElement>('[data-lb-artist]')!;
    const lbCount = lb.querySelector<HTMLElement>('[data-lb-count]')!;
    const lbVariants = lb.querySelector<HTMLElement>('[data-lb-variants]')!;

    let items: HTMLElement[] = [];
    let index = 0;
    let variant: Variant = 'fresh';

    const cardImg = (card: HTMLElement, v: Variant) =>
      card.querySelector<HTMLImageElement>(`img.variant-${v}`);

    const syncCardVariant = (card: HTMLElement, v: Variant) => {
      cardImg(card, 'fresh')?.classList.toggle('hidden', v !== 'fresh');
      cardImg(card, 'healed')?.classList.toggle('hidden', v !== 'healed');
      card
        .querySelectorAll<HTMLElement>('.seg[data-variant]')
        .forEach((s) => s.classList.toggle('active', s.dataset.variant === v));
    };

    const render = (fade = true) => {
      const card = items[index];
      if (!card) return;
      const hasFresh = !!cardImg(card, 'fresh');
      const hasHealed = !!cardImg(card, 'healed');
      if ((variant === 'fresh' && !hasFresh) || (variant === 'healed' && !hasHealed))
        variant = hasFresh ? 'fresh' : 'healed';
      const img = cardImg(card, variant)!;

      if (fade) lbImg.style.opacity = '0';
      lbImg.onload = () => (lbImg.style.opacity = '1');
      lbImg.src = img.currentSrc || img.src;
      lbImg.alt = img.alt;
      if (lbImg.complete) lbImg.style.opacity = '1';

      lbStyle.textContent = card.querySelector('.caption-style')?.textContent?.trim() ?? '';
      lbArtist.textContent = card.querySelector('.caption-artist')?.textContent?.trim() ?? '';
      lbCount.textContent = items.length > 1 ? `${index + 1} / ${items.length}` : '';

      lbVariants.classList.toggle('show', hasFresh && hasHealed);
      lbVariants
        .querySelectorAll<HTMLElement>('[data-lb-variant]')
        .forEach((s) => s.classList.toggle('active', s.dataset.lbVariant === variant));

      const nav = items.length > 1;
      lb.querySelectorAll<HTMLElement>('.lb-nav').forEach((b) => b.classList.toggle('hidden', !nav));
    };

    const openLb = (card: HTMLElement) => {
      items = [...root.querySelectorAll<HTMLElement>('.gallery-card[data-photo]:not(.hidden)')];
      index = Math.max(0, items.indexOf(card));
      variant = cardImg(card, 'fresh')?.classList.contains('hidden') ? 'healed' : 'fresh';
      render(false);
      lb.classList.add('open');
      document.documentElement.style.overflow = 'hidden';
      lb.querySelector<HTMLElement>('[data-lb-close]')?.focus();
    };

    const closeLb = () => {
      lb.classList.remove('open');
      document.documentElement.style.overflow = '';
    };

    const step = (dir: number) => {
      if (items.length < 2) return;
      index = (index + dir + items.length) % items.length;
      render();
    };

    /* ---------- events ---------- */
    root.addEventListener('click', (event) => {
      const el = event.target as HTMLElement;

      // lightbox controls
      if (el.closest('[data-lb-close]')) return closeLb();
      if (el.closest('[data-lb-prev]')) return step(-1);
      if (el.closest('[data-lb-next]')) return step(1);
      const lbSeg = el.closest<HTMLElement>('[data-lb-variant]');
      if (lbSeg) {
        variant = lbSeg.dataset.lbVariant as Variant;
        render();
        const card = items[index];
        if (card) syncCardVariant(card, variant);
        return;
      }
      // tap on the dimmed area (not the image) closes
      if (lb.classList.contains('open') && (el === lb || el.dataset.lbStage !== undefined))
        return closeLb();

      // filter chips
      const styleChip = el.closest<HTMLElement>('[data-filter-style]');
      const artistChip = el.closest<HTMLElement>('[data-filter-artist]');
      if (styleChip || artistChip) {
        const chip = (styleChip ?? artistChip)!;
        const key = styleChip ? 'style' : 'artist';
        const attr = styleChip ? 'data-filter-style' : 'data-filter-artist';
        state[key as 'style' | 'artist'] = chip.getAttribute(attr)!;
        chip.parentElement
          ?.querySelectorAll('.fchip')
          .forEach((c) => c.classList.toggle('active', c === chip));
        applyFilters();
        return;
      }

      // fresh/healed toggle on a card
      const seg = el.closest<HTMLElement>('.seg[data-variant]');
      if (seg) {
        const card = seg.closest<HTMLElement>('.gallery-card');
        if (card) syncCardVariant(card, seg.dataset.variant as Variant);
        return;
      }

      // tap on a photo opens the lightbox
      const opener = el.closest<HTMLElement>('[data-lb-open]');
      const photoCard = opener?.closest<HTMLElement>('.gallery-card[data-photo]');
      if (photoCard) openLb(photoCard);
    });

    // keyboard: Esc closes, arrows navigate (scoped to this page visit)
    const ac = new AbortController();
    document.addEventListener(
      'keydown',
      (event) => {
        if (!lb.classList.contains('open')) return;
        if (event.key === 'Escape') closeLb();
        else if (event.key === 'ArrowLeft') step(-1);
        else if (event.key === 'ArrowRight') step(1);
      },
      { signal: ac.signal },
    );
    document.addEventListener(
      'astro:before-swap',
      () => {
        closeLb();
        ac.abort();
      },
      { once: true },
    );

    // touch: horizontal swipe navigates, downward swipe closes
    let touchX = 0;
    let touchY = 0;
    lb.addEventListener(
      'touchstart',
      (event) => {
        touchX = event.touches[0]!.clientX;
        touchY = event.touches[0]!.clientY;
      },
      { passive: true },
    );
    lb.addEventListener(
      'touchend',
      (event) => {
        const dx = event.changedTouches[0]!.clientX - touchX;
        const dy = event.changedTouches[0]!.clientY - touchY;
        if (Math.abs(dx) > 48 && Math.abs(dx) > Math.abs(dy) * 1.5) step(dx < 0 ? 1 : -1);
        else if (dy > 72 && Math.abs(dy) > Math.abs(dx) * 1.5) closeLb();
      },
      { passive: true },
    );
  }
  document.addEventListener('astro:page-load', initGallery);
</script>
