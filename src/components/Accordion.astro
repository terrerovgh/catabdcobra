---
interface Props {
  q: string;
  a: string;
}
const { q, a } = Astro.props;
---

<details class="group rounded-2xl border border-line bg-surface shadow-(--shadow-card)">
  <summary
    class="flex cursor-pointer items-center justify-between gap-3 rounded-2xl p-4 font-display text-sm font-semibold select-none [&::-webkit-details-marker]:hidden"
  >
    {q}
    <svg
      viewBox="0 0 24 24"
      class="h-4 w-4 shrink-0 text-ink-soft transition-transform duration-300 group-open:rotate-180"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 9 L12 16 L19 9"></path>
    </svg>
  </summary>
  <p class="px-4 pb-4 text-sm leading-relaxed text-ink-soft">{a}</p>
</details>
