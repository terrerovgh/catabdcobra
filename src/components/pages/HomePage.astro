---
import AppLayout from '../../layouts/AppLayout.astro';
import LogoScene from '../LogoScene.astro';
import SwipeDeck from '../SwipeDeck.astro';
import StyleCard from '../StyleCard.astro';
import Cat from '../characters/Cat.astro';
import { styles } from '../../data/styles';
import { artists } from '../../data/artists';
import { localePath, useDict, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useDict(locale);
---

<AppLayout locale={locale} brandInHero>
  <!-- hero: the animated logo -->
  <section class="snap-section px-6 pt-4 text-center">
    <LogoScene />
    <h1 class="font-brand mt-2 text-4xl font-semibold">{t.home.heroTitle}</h1>
    <p class="mt-2 font-display text-xs font-bold tracking-[0.22em] text-accent-strong uppercase">
      {t.home.tagline}
    </p>
    <p class="mt-2 text-sm text-ink-soft">{t.home.heroSub}</p>
    <a
      href={localePath(locale, '/booking')}
      class="mt-6 inline-block rounded-full bg-accent px-8 py-3 font-display font-semibold text-charcoal shadow-(--shadow-float) transition-transform active:scale-[0.98]"
    >
      {t.common.bookNow}
    </a>
    <div class="anim-float mt-8 text-ink-soft" aria-hidden="true">
      <svg viewBox="0 0 24 24" class="mx-auto h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 14 L12 8 L18 14"></path>
      </svg>
      <p class="text-[0.65rem] font-bold tracking-widest uppercase">{t.home.swipeCue}</p>
    </div>
  </section>

  <!-- about -->
  <section class="snap-section mt-14 px-6">
    <div class="rounded-(--radius-card) border border-line bg-surface p-6 shadow-(--shadow-card)">
      <h2 class="font-display text-2xl font-semibold">{t.home.aboutTitle}</h2>
      <p class="mt-3 text-sm leading-relaxed text-ink-soft">{t.home.aboutBody}</p>
    </div>
  </section>

  <!-- styles deck -->
  <section class="snap-section mt-14">
    <div class="px-6">
      <h2 class="font-display text-2xl font-semibold">{t.home.stylesTitle}</h2>
      <p class="mt-1 text-sm text-ink-soft">{t.home.stylesSub}</p>
    </div>
    <SwipeDeck class="mt-2">
      {styles.map((style) => <StyleCard style={style} locale={locale} />)}
    </SwipeDeck>
  </section>

  <!-- artists teaser -->
  <section class="snap-section mt-14 px-6">
    <h2 class="font-display text-2xl font-semibold">{t.home.artistsTitle}</h2>
    <p class="mt-1 text-sm text-ink-soft">{t.home.artistsSub}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {
        artists.map((artist) => (
          <a
            href={`${localePath(locale, '/artists')}#${artist.id}`}
            class="flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1.5 text-xs font-bold transition-transform active:scale-[0.98]"
          >
            <span class="h-2.5 w-2.5 rounded-full" style={`background:${artist.accent}`} aria-hidden="true" />
            {artist.handle}
          </a>
        ))
      }
    </div>
    <a
      href={localePath(locale, '/artists')}
      class="mt-5 inline-block rounded-full border border-accent px-6 py-2.5 font-display text-sm font-semibold text-accent-strong transition-transform active:scale-[0.98]"
    >
      {t.home.meetArtists}
    </a>
  </section>

  <!-- visit -->
  <section class="snap-section mt-14 px-6">
    <div class="rounded-(--radius-card) border border-line bg-surface p-6 shadow-(--shadow-card)">
      <h2 class="font-display text-2xl font-semibold">{t.home.visitTitle}</h2>
      <p class="mt-2 text-sm text-ink-soft">{t.home.visitBody}</p>
      <a
        href="https://maps.google.com/?q=301+Washington+St+SE,+Albuquerque,+NM+87108"
        target="_blank"
        rel="noopener"
        class="mt-3 flex items-center gap-2 text-sm font-bold text-accent-strong"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 21 C8 16.5 5.5 13 5.5 9.8 A6.5 6.5 0 0 1 18.5 9.8 C18.5 13 16 16.5 12 21 Z"></path>
          <circle cx="12" cy="9.8" r="2.3"></circle>
        </svg>
        {t.home.address}
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="snap-section mt-14 px-6">
    <div class="relative overflow-hidden rounded-(--radius-card) bg-accent p-6 text-charcoal shadow-(--shadow-float)">
      <div class="relative z-10 max-w-[60%]">
        <h2 class="font-display text-2xl font-semibold">{t.home.ctaTitle}</h2>
        <p class="mt-2 text-sm font-medium opacity-80">{t.home.ctaBody}</p>
        <a
          href={localePath(locale, '/booking')}
          class="mt-4 inline-block rounded-full bg-charcoal px-6 py-2.5 font-display text-sm font-semibold text-cream transition-transform active:scale-[0.98]"
        >
          {t.common.bookNow}
        </a>
      </div>
      <Cat class="absolute -right-8 -bottom-4 w-48 opacity-90" />
    </div>
  </section>
</AppLayout>

<style is:global>
  html {
    scroll-snap-type: y proximity;
  }
  .snap-section {
    scroll-snap-align: start;
    scroll-margin-top: calc(4.5rem + env(safe-area-inset-top));
  }
</style>
