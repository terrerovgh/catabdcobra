---
import AppLayout from '../../layouts/AppLayout.astro';
import AftercareTimeline from '../AftercareTimeline.astro';
import Accordion from '../Accordion.astro';
import Cobra from '../characters/Cobra.astro';
import { useDict, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useDict(locale);
---

<AppLayout locale={locale} title={t.aftercare.title}>
  <section class="px-6 pt-6" data-aftercare>
    <h1 class="font-display text-3xl font-semibold">{t.aftercare.title}</h1>
    <p class="mt-1 text-sm text-ink-soft">{t.aftercare.sub}</p>

    <!-- protocol tabs -->
    <div class="mt-5 flex rounded-full border border-line bg-surface p-1" role="tablist">
      <button
        type="button"
        role="tab"
        aria-selected="true"
        data-tab="traditional"
        class="tab active flex-1 rounded-full py-2 font-display text-sm font-semibold transition-colors"
      >
        {t.aftercare.tabTraditional}
      </button>
      <button
        type="button"
        role="tab"
        aria-selected="false"
        data-tab="wrap"
        class="tab flex-1 rounded-full py-2 font-display text-sm font-semibold transition-colors"
      >
        {t.aftercare.tabWrap}
      </button>
    </div>

    <div data-panel="traditional" class="mt-6">
      <AftercareTimeline steps={t.aftercare.traditional} />
    </div>

    <div data-panel="wrap" class="mt-6 hidden">
      <AftercareTimeline steps={t.aftercare.wrap} />
      <p class="mt-5 rounded-2xl border border-line bg-surface p-4 text-sm leading-relaxed text-ink-soft">
        {t.aftercare.wrapNote}
      </p>
      <p class="mt-3 rounded-2xl border-2 border-accent-strong/60 bg-surface p-4 text-sm leading-relaxed font-medium">
        ⚠️ {t.aftercare.wrapWarning}
      </p>
    </div>

    <!-- the cobra says no -->
    <div class="mt-12">
      <div class="flex items-end gap-3">
        <Cobra class="h-20 shrink-0" />
        <h2 class="pb-1 font-display text-2xl font-semibold">{t.aftercare.warningsTitle}</h2>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-3">
        {
          t.aftercare.warnings.map((w) => (
            <div class="rounded-2xl border border-line bg-surface p-4 shadow-(--shadow-card)">
              <h3 class="font-display text-sm font-semibold text-accent-strong">{w.title}</h3>
              <p class="mt-1 text-xs leading-relaxed text-ink-soft">{w.body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- common concerns -->
    <div class="mt-12">
      <h2 class="font-display text-2xl font-semibold">{t.aftercare.concernsTitle}</h2>
      <div class="mt-4 space-y-3">
        {t.aftercare.concerns.map((c) => <Accordion q={c.q} a={c.a} />)}
      </div>
    </div>
  </section>
</AppLayout>

<style>
  .tab.active {
    background: var(--accent);
    color: #26231f;
  }
</style>

<script>
  function initAftercare() {
    const root = document.querySelector<HTMLElement>('[data-aftercare]');
    if (!root || root.dataset.init) return;
    root.dataset.init = '1';

    root.querySelectorAll<HTMLElement>('[data-tab]').forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        root.querySelectorAll<HTMLElement>('[data-tab]').forEach((b) => {
          const active = b === tab;
          b.classList.toggle('active', active);
          b.setAttribute('aria-selected', String(active));
        });
        root
          .querySelectorAll<HTMLElement>('[data-panel]')
          .forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== target));
      });
    });
  }
  document.addEventListener('astro:page-load', initAftercare);
</script>
