---
/** Miniature of the logo: the original emblem artwork, rendered static at
 *  header size (192px asset for crisp high-DPI rendering). */
interface Props {
  class?: string;
}
const { class: className = 'h-9 w-9' } = Astro.props;
---

<img
  src="/logo/logo-mark.webp"
  class={className}
  width="192"
  height="192"
  alt=""
  aria-hidden="true"
  decoding="async"
  draggable="false"
/>
