---
import { Image } from 'astro:assets';
import type { Artist } from '../data/artists';
import { getArtistPhoto } from '../data/artistPhotos';
import { getStyle } from '../data/styles';
import { localePath, useDict, type Locale } from '../i18n';
import Cat from './characters/Cat.astro';
import Cobra from './characters/Cobra.astro';

interface Props {
  artist: Artist;
  locale: Locale;
  id?: string;
}
const { artist, locale, id } = Astro.props;
const t = useDict(locale);
const styleNames = artist.styles
  .map((sid) => getStyle(sid)?.name[locale])
  .filter(Boolean) as string[];
const galleryHref = `${localePath(locale, '/gallery')}#artist=${artist.id}`;
const photo = getArtistPhoto(artist.id);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const samplesApi = `${base}/api/public/profile-gallery/${artist.id}`;
---

<article
  id={id}
  class="swipe-card relative flex w-72 flex-col overflow-hidden rounded-(--radius-card) border border-line bg-surface p-6 shadow-(--shadow-card)"
>
  <!-- Instagram profile photo (or mascot fallback) -->
  <div class="relative mx-auto grid h-32 w-32 place-items-center">
    <span
      class="absolute inset-0 rounded-full opacity-30"
      style={`background:${artist.accent}`}
      aria-hidden="true"></span>
    <span
      class="absolute inset-2 rounded-full opacity-40"
      style={`background:${artist.accent}`}
      aria-hidden="true"></span>
    {
      photo ? (
        <Image
          src={photo}
          alt={artist.handle}
          width={256}
          height={256}
          class="relative z-10 h-28 w-28 rounded-full object-cover ring-2 ring-surface shadow-(--shadow-card)"
        />
      ) : artist.mood === 'cat' ? (
        <Cat class="relative w-28 translate-y-1.5" />
      ) : (
        <Cobra class="relative h-28" />
      )
    }
  </div>

  <h3 class="mt-4 text-center font-display text-xl font-semibold">{artist.handle}</h3>
  <p class="text-center text-xs font-bold tracking-widest text-ink-soft uppercase">
    {artist.role === 'owner' ? t.artists.owner : t.artists.resident}
  </p>

  <div class="mt-3 flex flex-wrap justify-center gap-1.5">
    {
      styleNames.map((name) => (
        <span class="rounded-full border border-line bg-surface-2 px-2.5 py-0.5 text-xs font-semibold">
          {name}
        </span>
      ))
    }
  </div>

  <!-- Samples: only images selected for this artist's profile (show_in_profile) -->
  <a
    href={galleryHref}
    class="mt-3 hidden grid-cols-3 gap-1.5"
    aria-label={t.artists.seeWork}
    data-artist-samples
    data-samples-api={samplesApi}
  ></a>

  <p class="mt-3 grow text-sm leading-relaxed text-ink-soft">{artist.bio[locale]}</p>

  <div class="mt-5 flex gap-2">
    <a
      href={artist.instagram}
      target="_blank"
      rel="noopener"
      class="flex-1 rounded-full border border-line py-2.5 text-center text-sm font-bold transition-colors hover:bg-surface-2"
    >
      {t.common.follow}
    </a>
    <a
      href={`${localePath(locale, '/booking')}#${artist.id}`}
      class="flex-1 rounded-full bg-accent py-2.5 text-center text-sm font-bold text-charcoal transition-colors hover:bg-accent-strong"
    >
      {t.nav.booking}
    </a>
  </div>
</article>

<script>
  function loadArtistSamples() {
    document.querySelectorAll<HTMLElement>('[data-artist-samples]').forEach((el) => {
      if (el.dataset.init) return;
      el.dataset.init = '1';
      const api = el.dataset.samplesApi;
      if (!api) return;
      fetch(api)
        .then((r) => r.json())
        .then((json) => {
          if (!json?.ok) return;
          const items = (json.data?.media || []).slice(0, 3) as { url: string }[];
          if (!items.length) return;
          el.classList.remove('hidden');
          el.classList.add('grid');
          el.innerHTML = items
            .map(
              (m) =>
                `<img src="${m.url}" alt="" width="160" height="160" loading="lazy" class="aspect-square w-full rounded-lg object-cover" />`,
            )
            .join('');
        })
        .catch(() => {});
    });
  }
  document.addEventListener('astro:page-load', loadArtistSamples);
</script>
