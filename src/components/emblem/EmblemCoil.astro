---
/**
 * Emblem layer: the cobra's coil draped over the cat's back, traced 1:1
 * from the studio logo video (720×720 scene grid shared by all emblem
 * layers). A folded sage lobe with a fold seam and one continuous cream
 * belly band — small scutes crossing the back, wrapping around the tip.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg class={`emblem-coil ${className}`} viewBox="0 0 720 720" fill="none" aria-hidden="true" role="img">
  <g transform="translate(2 -55)">
    <!-- coil body -->
    <path d="M326 414
             C368 388 440 382 500 400
             C556 416 598 448 610 482
             C616 504 610 522 592 530
             C576 534 560 532 548 524
             C534 548 510 560 488 553
             C468 547 458 532 460 513
             C458 494 450 476 434 462
             C410 442 366 426 326 414 Z"
          fill="#8fa38e" stroke="#6b5334" stroke-width="6.5" stroke-linejoin="round"></path>
    <!-- fold seam -->
    <path d="M394 428 C448 450 492 486 506 524" stroke="#6b5334" stroke-width="5" stroke-linecap="round"></path>
    <!-- continuous belly band along the lower edge, wrapping the tip -->
    <path d="M336 424 C372 434 404 446 426 466 C444 482 452 500 456 518 C459 538 470 550 490 548 C508 546 518 534 516 518"
          stroke="#6b5334" stroke-width="24" stroke-linecap="round"></path>
    <path d="M336 424 C372 434 404 446 426 466 C444 482 452 500 456 518 C459 538 470 550 490 548 C508 546 518 534 516 518"
          stroke="#eee0bd" stroke-width="17" stroke-linecap="round"></path>
    <g stroke="#6b5334" stroke-width="3.2" stroke-linecap="round">
      <path d="M356 420 L352 436"></path>
      <path d="M381 428 L375 444"></path>
      <path d="M406 441 L398 455"></path>
      <path d="M429 458 L419 470"></path>
      <path d="M446 477 L434 487"></path>
      <path d="M457 497 L443 503"></path>
      <path d="M464 517 L448 519"></path>
      <path d="M469 532 L455 540"></path>
      <path d="M479 538 L473 554"></path>
      <path d="M493 540 L495 556"></path>
      <path d="M504 533 L516 543"></path>
    </g>
  </g>
</svg>
