---
/**
 * The logo scene rebuilt in layers: peach disc at the back, cobra rising
 * behind, cat lounging in front, floating specks. Layers drift at
 * different depths following pointer / device tilt.
 */
import Cat from './characters/Cat.astro';
import Cobra from './characters/Cobra.astro';
---

<div class="hero-scene relative mx-auto aspect-square w-full max-w-sm" data-hero-scene>
  <!-- halo disc -->
  <div
    class="hero-layer absolute inset-[7%] rounded-full transition-colors duration-300"
    style="--depth: 6px; background: var(--scene-disc); box-shadow: 0 30px 60px -30px var(--shadow)"
  >
  </div>

  <!-- floating specks -->
  <div class="hero-layer absolute inset-0" style="--depth: 22px" aria-hidden="true">
    <span class="anim-float absolute top-[12%] left-[16%] h-2 w-2 rounded-full bg-blush opacity-80"></span>
    <span class="anim-float absolute top-[22%] right-[12%] h-3 w-3 rounded-full bg-duo opacity-70" style="animation-delay: -2s"></span>
    <span class="anim-float absolute bottom-[18%] left-[8%] h-2.5 w-2.5 rounded-full bg-accent opacity-70" style="animation-delay: -4s"></span>
    <span class="anim-float absolute right-[6%] bottom-[30%] h-2 w-2 rounded-full bg-blush opacity-60" style="animation-delay: -1s"></span>
  </div>

  <!-- cobra behind -->
  <div class="hero-layer absolute top-[4%] right-[10%] w-[42%]" style="--depth: 12px">
    <Cobra class="w-full drop-shadow-lg" />
  </div>

  <!-- cat in front -->
  <div class="hero-layer absolute bottom-[13%] left-[8%] w-[76%]" style="--depth: 18px">
    <Cat class="w-full drop-shadow-xl" />
  </div>
</div>

<style>
  .hero-layer {
    transform: translate3d(
      calc(var(--px, 0) * var(--depth, 10px)),
      calc(var(--py, 0) * var(--depth, 10px)),
      0
    );
    transition: transform 200ms ease-out;
    will-change: transform;
  }
</style>

<script>
  function initHero() {
    const scene = document.querySelector<HTMLElement>('[data-hero-scene]');
    if (!scene || scene.dataset.init) return;
    scene.dataset.init = '1';
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const set = (x: number, y: number) => {
      scene.style.setProperty('--px', String(Math.max(-1, Math.min(1, x))));
      scene.style.setProperty('--py', String(Math.max(-1, Math.min(1, y))));
    };

    window.addEventListener(
      'pointermove',
      (e) => {
        const r = scene.getBoundingClientRect();
        set(
          (e.clientX - (r.left + r.width / 2)) / (r.width / 2),
          (e.clientY - (r.top + r.height / 2)) / (r.height / 2),
        );
      },
      { passive: true },
    );

    window.addEventListener(
      'deviceorientation',
      (e) => {
        if (e.gamma == null || e.beta == null) return;
        set(e.gamma / 30, (e.beta - 45) / 30);
      },
      { passive: true },
    );
  }
  document.addEventListener('astro:page-load', initHero);
</script>
