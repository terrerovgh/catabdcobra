---
import { ClientRouter } from 'astro:transitions';
import { localePath, useDict, type Locale } from '../i18n';
import TabBar from '../components/TabBar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import LangToggle from '../components/LangToggle.astro';
import BrandMark from '../components/BrandMark.astro';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  /** Home passes true: the hero logo owns the "brand" view-transition name there. */
  brandInHero?: boolean;
}
const { locale, title, description, brandInHero = false } = Astro.props;
const t = useDict(locale);
const pageTitle = title ? `${title} · Cat & Cobra` : t.meta.title;
const pageDescription = description ?? t.meta.description;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f0e7c9" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        const colors = { cat: '#f0e7c9', cobra: '#26231f' };
        const apply = () => {
          const saved = localStorage.getItem('cc-theme');
          const theme =
            saved === 'cat' || saved === 'cobra'
              ? saved
              : matchMedia('(prefers-color-scheme: dark)').matches
                ? 'cobra'
                : 'cat';
          document.documentElement.dataset.theme = theme;
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', colors[theme]);
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
        document.addEventListener('click', (event) => {
          const btn = event.target && event.target.closest && event.target.closest('[data-theme-toggle]');
          if (!btn) return;
          const next = document.documentElement.dataset.theme === 'cobra' ? 'cat' : 'cobra';
          localStorage.setItem('cc-theme', next);
          apply();
        });
      })();
    </script>
  </head>
  <body>
    <header
      class="fixed inset-x-0 top-0 z-50 border-b border-line bg-bg/85 backdrop-blur-md"
      style="padding-top: env(safe-area-inset-top)"
    >
      <div class="mx-auto flex h-14 max-w-md items-center justify-between px-4">
        <a href={localePath(locale, '/')} class="flex items-center gap-2.5">
          {
            brandInHero ? (
              <div class="h-9 w-9">
                <BrandMark />
              </div>
            ) : (
              <div class="h-9 w-9" transition:name="brand">
                <BrandMark />
              </div>
            )
          }
          <span class="font-brand text-lg font-semibold">Cat & Cobra</span>
        </a>
        <div class="flex items-center gap-2">
          <LangToggle locale={locale} />
          <ThemeToggle locale={locale} />
        </div>
      </div>
    </header>

    <main
      class="mx-auto min-h-dvh max-w-md"
      style="padding-top: calc(3.5rem + env(safe-area-inset-top)); padding-bottom: calc(5rem + env(safe-area-inset-bottom))"
    >
      <slot />
    </main>

    <footer class="mx-auto max-w-md px-6 pb-28 pt-4 text-center text-xs text-ink-soft">
      <p class="font-display font-semibold">{t.footer.tagline}</p>
      <p class="mt-1">{t.footer.address}</p>
    </footer>

    <TabBar locale={locale} />
  </body>
</html>
