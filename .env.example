# Copy to .env and fill in values. Never commit .env.
# For wrangler local overrides, use .dev.vars (see .dev.vars.example if present).

# --- Instagram via RapidAPI (Instagram Scraper Stable API) ---
# https://rapidapi.com/thetechguy32744/api/instagram-scraper-stable-api
#
# Example request the tool mirrors:
#   POST https://instagram-scraper-stable-api.p.rapidapi.com/get_ig_user_posts.php
#   form: username_or_url, amount, pagination_token

INSTAGRAM_RAPIDAPI_KEY=
INSTAGRAM_RAPIDAPI_HOST=instagram-scraper-stable-api.p.rapidapi.com
INSTAGRAM_RAPIDAPI_POSTS_PATH=/get_ig_user_posts.php
INSTAGRAM_RAPIDAPI_METHOD=POST
INSTAGRAM_RAPIDAPI_AMOUNT=12

# Optional: official Meta Graph API (not used by the RapidAPI downloader)
INSTAGRAM_ACCESS_TOKEN=

# --- Admin / Worker ---
# Prefer .dev.vars for wrangler dev (not committed). Example:
#   ENVIRONMENT=development
#   EMAIL_FROM=noreply@terrerov.com
#
# ENVIRONMENT=development → OTP shown as devCode in admin when email send fails.
# EMAIL_FROM domain must be onboarded:
#   npx wrangler email sending enable terrerov.com
#
# Seed users (migrations/0002 + 0003, or Admin → Usuarios):
#   admin@terrerov.com              → system_admin
#   owner@catandcobra.com           → owner
#   flyingsnail@catandcobra.com     → artist
#   …other artists @catandcobra.com
#
# Public site only shows media with show_in_gallery=1 (admin: Mostrar en la web).
